<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating"
    android:paddingHorizontal="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_horizontal">

    <!-- 统计行 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvDanmuCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已读 0"
            android:textSize="13sp"
            android:textColor="@color/accent_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  "
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvSkippedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳过 0"
            android:textSize="13sp"
            android:textColor="@color/accent_red" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  "
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="折叠"
            android:textSize="13sp"
            android:textColor="@color/accent_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 展开态控制区 -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 播放 + 语速行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btnPlayPause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="⏸"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnSpeedDown"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="−"
                android:textSize="24sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.5x"
                android:textSize="16sp"
                android:textColor="@color/accent_yellow"
                android:textStyle="bold"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/btnSpeedUp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="+"
                android:textSize="24sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 功能按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnReplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏮ 上一条"
                android:textSize="14sp"
                android:textColor="@color/accent_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btnSkipLatest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏭ 跳最新"
                android:textSize="14sp"
                android:textColor="@color/accent_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- 折叠态隐藏信息 -->
    <LinearLayout
        android:id="@+id/layoutCollapsedInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvCollapsedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="14sp"
            android:textColor="@color/accent_green"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>