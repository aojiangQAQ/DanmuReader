<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 声明需要查询 TTS 服务，解决 Android 11+ 包可见性限制 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <!-- 也查询 TTS 数据检查 -->
        <intent>
            <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
        </intent>
        <!-- 常见 TTS 引擎包名，确保能被发现 -->
        <package android:name="com.google.android.tts" />
        <package android:name="com.github.olga_yakovleva.RhVoice.android" />
        <package android:name="com.iflytek.vflynote" />
        <package android:name="com.iflytek.speechcloud" />
        <package android:name="com.svox.pico" />
        <!-- 国产手机常见内置 TTS -->
        <package android:name="com.miui.tsmclient" />
        <package android:name="com.huawei.speech" />
        <package android:name="com.heytap.speechassist" />
        <package android:name="com.samsung.android.tts" />
        <package android:name="com.vivo.speechassist" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.DanmuReader"
        android:supportsRtl="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".DanmuAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="设置" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>